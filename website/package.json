{
  "name": "lux-study-agency",
  "version": "1.0.0",
  "private": true,
  "description": "Lux Study Agency — marketing site (single responsive page)",
  "scripts": {
    "watch:css": "tailwindcss -i ./src/input.css -o ./dist/output.css --watch",
    "build:css": "tailwindcss -i ./src/input.css -o ./dist/output.css --minify",
    "serve": "serve -l 3000 .",
    "dev": "concurrently -n tailwind,serve -c blue,green \"npm:watch:css\" \"npm:serve\"",
    "build": "npm run build:css"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.13",
    "concurrently": "^9.0.1",
    "serve": "^14.2.3"
  }
}
